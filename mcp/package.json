{
    "name": "mcp-google-workspace",
    "version": "1.0.0",
    "description": "MCP server that proxies Google Workspace tool calls to a Google Apps Script web app",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "dev": "tsc --watch",
        "start": "node dist/index.js",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "@types/express": "^5.0.6",
        "commander": "^14.0.3",
        "dotenv": "^16.4.5",
        "express": "^5.2.1",
        "mcporter": "^0.7.3",
        "zod": "^3.23.8",
        "zod-to-json-schema": "^3.25.1"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=18"
    }
}
